# Anthropic API key — required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Claude model used by every agent (Orchestrator, Policy Validator, Refund Resolver).
# Defaults to Opus 4.8; override to e.g. claude-sonnet-5 for lower cost/latency.
CLAUDE_MODEL=claude-opus-4-8

# SQLite database file. Defaults to backend/db/melodymaxgear.db if unset.
DB_PATH=backend/db/melodymaxgear.db

# Refund policy document read by the policy_check tool.
POLICY_PATH=policy/refund_policy.md

# Flask server
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# Manager escalation thresholds
MANAGER_APPROVAL_THRESHOLD=500
NO_RECEIPT_HIGH_VALUE_THRESHOLD=150

# Comma-separated allowed origins for CORS, or * for all (dev default).
CORS_ORIGINS=*

# Voice pipeline (optional) — Whisper speech-to-text and ElevenLabs
# text-to-speech. Purely additive: if either key is left blank, the voice
# endpoints fail gracefully and the frontend falls back to text-only chat.
OPENAI_API_KEY=sk-your-openai-key-here
ELEVENLABS_API_KEY=your-elevenlabs-key-here
# Rachel — a calm, professional voice well suited to customer support.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
